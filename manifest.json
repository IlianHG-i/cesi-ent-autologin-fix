{
   "action": {
      "default_popup": "popup/popup.html"
   },
   "author": "Hugo",
   "background": {
      "service_worker": "js/start.js",
      "scripts": [ "js/start.js" ]
   },
   "browser_specific_settings": {
      "gecko": {
         "id": "cesi-ent-autologin-fix@ilianhg.local",
         "strict_min_version": "109.0",
         "update_url": "https://raw.githubusercontent.com/IlianHG-i/cesi-ent-autologin-fix/main/updates.json"
      }
   },
   "content_scripts": [ {
      "js": [ "js/content-moodle.js" ],
      "matches": [ "https://moodle-ingenieurs.cesi.fr/*" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/content-moodle-fix.js" ],
      "matches": [ "https://moodle-ingenieurs.cesi.fr/*" ],
      "run_at": "document_start"
   }, {
      "js": [ "js/content-moodle-iframe.js" ],
      "matches": [ "https://moodle-ingenieurs.cesi.fr/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "js/content-ent.js" ],
      "matches": [ "https://wayf.cesi.fr/*", "https://sts.viacesi.fr/*", "https://ent.cesi.fr/*" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/content-ent-fix.js" ],
      "matches": [ "https://wayf.cesi.fr/*", "https://sts.viacesi.fr/*", "https://ent.cesi.fr/*" ],
      "run_at": "document_start"
   }, {
      "exclude_matches": [ "https://wayf.cesi.fr/login*client_name*" ],
      "js": [ "js/ent.user.js" ],
      "matches": [ "https://wayf.cesi.fr/login*service*" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/ent-wayf.user.js" ],
      "matches": [ "https://ent.cesi.fr/identification/wayf*" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/moodle.user.js" ],
      "matches": [ "https://moodle-ingenieurs.cesi.fr/login*", "https://moodle-ingenieurs.cesi.fr/login/index.php?authCAS=CAS" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/moodle.cesi.fr.user.js" ],
      "matches": [ "https://moodle.cesi.fr/login/index.php*", "https://moodle.cesi.fr/login/index.php?authCAS=CAS" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/moodle-examens.user.js" ],
      "matches": [ "https://moodle-examens.cesi.fr/login/*" ],
      "run_at": "document_end"
   }, {
      "js": [ "js/ent-ad.user.js" ],
      "matches": [ "https://sts.viacesi.fr/adfs/ls/*" ],
      "run_at": "document_end"
   } ],
   "content_security_policy": {
   },
   "description": "Thème noir + Autologin pour soulager vos yeux sur l'ENT CESI",
   "homepage_url": "https://www.hugodevland.fr/",
   "icons": {
      "128": "icons/icon_x128.png",
      "16": "icons/icon_x16.png",
      "32": "icons/icon_x32.png",
      "48": "icons/icon_x48.png"
   },
   "manifest_version": 3,
   "name": "Thème noir + Autologin ENT CESI",
   "permissions": [ "storage" ],
   "version": "4.8.8",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "icon/*.png", "images/*.png", "icons/*.png", "css/*.css" ]
   } ]
}
